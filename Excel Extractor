import streamlit as st
import pandas as pd
import numpy as np
from indeterminatebeam import Beam, Support, PointLoadV, PointLoadH, DistributedLoadV, TrapezoidalLoadV, PointTorque
import plotly.graph_objects as go
import subprocess  # For running original repo examples if cloned
import os

st.title("Indeterminate Beam Calculator with Standard Profiles from Excel")
st.markdown("Uses IndeterminateBeam package. Load profiles from 'beam_profiles.xlsx'. Add supports, loads, and analyze.")

# Load profiles from Excel (assume one sheet per standard)
try:
    profiles = {}
    xls = pd.ExcelFile('beam_profiles.xlsx')
    for sheet in xls.sheet_names:
        profiles[sheet] = pd.read_excel(xls, sheet_name=sheet).to_dict('records')
except FileNotFoundError:
    st.error("Missing 'beam_profiles.xlsx' – add it to the repo root with sheets for each standard.")
    profiles = {}  # Fallback empty

steel_grades = {
    "S235": 2.10e11,
    "S275": 2.10e11,
    "S355": 2.10e11,
    "S460": 2.10e11,
    "MoCr": 2.10e11,
}

# Beam properties
length = st.number_input("Beam Length (m)", min_value=0.1, value=6.0, step=0.1)

standard = st.selectbox("Beam Standard / Family", list(profiles.keys()) or ["No profiles loaded"])
if standard in profiles:
    profile_options = [p["Name"] for p in profiles[standard]]
    profile_name = st.selectbox("Profile", profile_options)
    profile = next(p for p in profiles[standard] if p["Name"] == profile_name)

    st.subheader("Selected Profile Properties")
    st.write(f"h = {profile['h (m)']:.3f} m | b = {profile['b (m)']:.3f} m | tw = {profile['tw (m)']:.4f} m | tf = {profile['tf (m)']:.4f} m")
    st.write(f"A = {profile['A (m²)']:.4e} m² | Ixx = {profile['Ixx (m⁴)']:.3e} m⁴")

    I = profile["Ixx (m⁴)"]
    A = profile["A (m²)"]
else:
    I = st.number_input("Ixx (m⁴)", value=8.6e-6)
    A = st.number_input("A (m²)", value=2.32e-3)

grade = st.selectbox("Steel Grade", list(steel_grades.keys()))
E = steel_grades[grade]
G_input = st.number_input("Shear Modulus G (Pa; 0 = Euler-Bernoulli)", value=8.1e10)
G = None if G_input <= 0 else G_input

beam = Beam(length, E=E, I=I, A=A, G=G)

# Supports (similar to previous)
st.subheader("Supports")
if 'supports' not in st.session_state:
    st.session_state.supports = [{"x": 0.0, "fx": False, "fy": True, "m": False}, {"x": length, "fx": False, "fy": True, "m": False}]

num_sup = st.number_input("Number of Supports", 1, 10, len(st.session_state.supports))
while len(st.session_state.supports) < num_sup:
    st.session_state.supports.append({"x": 0.0, "fx": False, "fy": True, "m": False})
while len(st.session_state.supports) > num_sup:
    st.session_state.supports.pop()

for i, s in enumerate(st.session_state.supports):
    with st.expander(f"Support {i+1}"):
        s["x"] = st.number_input("Position (m)", 0.0, length, s["x"], key=f"s_x_{i}")
        col1, col2, col3 = st.columns(3)
        s["fx"] = col1.checkbox("Restrain X", s["fx"], key=f"s_fx_{i}")
        s["fy"] = col2.checkbox("Restrain Y", s["fy"], key=f"s_fy_{i}")
        s["m"] = col3.checkbox("Restrain Rotation", s["m"], key=f"s_m_{i}")

# Loads (with migration/fix from previous)
st.subheader("Loads")
type_mapping = {
    "Point Load Vertical": "Point Vertical (N)",
    # ... add others if needed
}
if 'loads' in st.session_state:
    for ld in st.session_state.loads:
        old_type = ld.get("type")
        if old_type in type_mapping:
            ld["type"] = type_mapping[old_type]
if 'loads' not in st.session_state:
    st.session_state.loads = []

load_types = ["Point Vertical (N)", "Point Horizontal (N)", "UDL (N/m)", "Trapezoidal (N/m → N/m)", "Point Moment (N·m)"]
num_loads = st.number_input("Number of Loads", 0, 15, len(st.session_state.loads) or 1)
while len(st.session_state.loads) < num_loads:
    st.session_state.loads.append({"type": "Point Vertical (N)", "x": length / 2, "value": -10000.0})
while len(st.session_state.loads) > num_loads:
    st.session_state.loads.pop()

for i, ld in enumerate(st.session_state.loads):
    with st.expander(f"Load {i+1}"):
        current_type = ld.get("type", "Point Vertical (N)")
        if current_type not in load_types:
            current_type = "Point Vertical (N)"
        ld["type"] = st.selectbox("Type", load_types, index=load_types.index(current_type), key=f"lt_{i}")
        ld["x"] = st.number_input("Position/Start (m)", 0.0, length, ld.get("x", length/2), key=f"lx_{i}")
        if "Vertical" in ld["type"]:
            ld["value"] = st.number_input("Force (N; - down)", ld.get("value", -10000.0), key=f"lv_{i}")
        # ... (similar for other types, as in previous code)

# Run Original Repo Examples (if cloned as submodule)
if st.button("Run Original Repo Example (readme_example.py)"):
    if os.path.exists("original_repo/docs/examples/readme_example.py"):
        try:
            result = subprocess.run(["python", "original_repo/docs/examples/readme_example.py"], capture_output=True, text=True)
            st.text(result.stdout)
            if result.stderr:
                st.error(result.stderr)
        except Exception as e:
            st.error(f"Failed to run: {e}")
    else:
        st.warning("Clone original repo as submodule first: git submodule add https://github.com/JesseBonanno/IndeterminateBeam original_repo")

