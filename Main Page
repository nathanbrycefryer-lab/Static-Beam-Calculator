import streamlit as st
from indeterminatebeam import Beam, Support, PointLoadV, PointLoadH, DistributedLoadV, PointTorque, TrapezoidalLoadV
import plotly.graph_objects as go
import pandas as pd
import numpy as np

st.title("Indeterminate 1D Beam Solver with Standard Profiles")
st.markdown("Select standard profile, grade, add supports/loads, and analyze. Units: SI (m, N, Pa). Loads downward = negative.")

# ==================== Beam Profiles (expanded with real data) ====================
profiles = {
    "European IPE": [
        {"name": "IPE 80", "h": 0.080, "b": 0.046, "tw": 0.0038, "tf": 0.0052, "A": 7.64e-4, "Ixx": 80.1e-8, "Iyy": 8.49e-8},
